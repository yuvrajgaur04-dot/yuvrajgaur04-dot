body
{
font-family: Arial;
background: linear-gradient(to right,#ff9a9e,#fad0c4);
margin:0;
}

header
{
background:#ff5722;
color:white;
text-align:center;
padding:20px;
}

nav
{
background:#ff9800;
text-align:center;
padding:10px;
}

nav a
{
color:white;
text-decoration:none;
margin:15px;
font-weight:bold;
}

nav a:hover
{
color:black;
}

.container
{
background:white;
margin:20px;
padding:20px;
border-radius:10px;
}

footer
{
background:#ff5722;
color:white;
text-align:center;
padding:10px;
}

input, textarea
{
width:100%;
padding:10px;
margin:10px 0;
}
